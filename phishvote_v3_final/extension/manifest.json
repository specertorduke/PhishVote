{
  "manifest_version": 3,
  "name": "PhishVote — Phishing Detector",
  "version": "3.0.0",
  "description": "Real-time phishing detection using PhishVote ensemble (RF+XGB+CB+LGBM+GB). Extracts all 30 UCI-2015 features from URL and live DOM. Capstone Research.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["models/*.json"],
      "matches":   ["<all_urls>"]
    }
  ]
}
